# Example environment configuration. Copy to `.env` and adjust.
# Grouped by component; each service uses its own prefix so fragments never
# collide. Never commit real secrets — supply them via a secret manager in prod.

# ----------------------------------------------------------------------------- #
# Core (root Settings — no prefix)
# ----------------------------------------------------------------------------- #
APP_NAME=loan-platform-backend
ENVIRONMENT=local            # local | dev | staging | prod | test
DEBUG=true
DATABASE_URL=postgresql+asyncpg://loan:loan@localhost:5432/loan_platform
DATABASE_ECHO=false

# ----------------------------------------------------------------------------- #
# Rule Engine service (RULE_ENGINE_)
# ----------------------------------------------------------------------------- #
RULE_ENGINE_REBUILD_ON_STARTUP=false
# RULE_ENGINE_MATRIX_PATH=src/app/services/rule_engine/data/Bank_Eligibility_Matrix.xlsx
# RULE_ENGINE_DECISIONS_DIR=src/app/services/rule_engine/decisions

# ----------------------------------------------------------------------------- #
# Auth service (AUTH_)
# ----------------------------------------------------------------------------- #
AUTH_JWT_SECRET=change-me
AUTH_JWT_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_TTL_SECONDS=900
AUTH_REFRESH_TOKEN_TTL_SECONDS=1209600
# AUTH_OAUTH_GOOGLE_CLIENT_ID=
# AUTH_OAUTH_GOOGLE_CLIENT_SECRET=

# ----------------------------------------------------------------------------- #
# Domain Logs service (DOMAIN_LOGS_)
# ----------------------------------------------------------------------------- #
DOMAIN_LOGS_HEARTBEAT_SECONDS=15
DOMAIN_LOGS_MAX_BUFFER_LINES=1000

# ----------------------------------------------------------------------------- #
# OCR Jobs service (OCR_)
# ----------------------------------------------------------------------------- #
OCR_BROKER_URL=redis://localhost:6379/0
OCR_RESULT_BACKEND=redis://localhost:6379/1
OCR_ENGINE=tesseract
OCR_STORAGE_ROOT=/var/lib/ocr-artifacts
